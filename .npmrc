# Route @Kubaphone91-scoped packages to GitHub Packages.
# This file is safe to commit — it contains no secrets.
#
# Auth is handled separately:
#   CI:    setup-node injects NODE_AUTH_TOKEN via registry-url
#   Local: add to ~/.npmrc → //npm.pkg.github.com/:_authToken=<your-PAT>
@Kubaphone91:registry=https://npm.pkg.github.com
